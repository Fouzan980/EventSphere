# ── Copy this file to .env and fill in your real values ──────────────────────

# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eventsphere?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_long_random_jwt_secret_here

# Server Port
PORT=5000

# Gmail SMTP (use an App Password, not your main password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_gmail_app_password

# Google Maps API Key (for reverse geocoding)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Spotify API (for speaker/artist search)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
